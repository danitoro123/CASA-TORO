# Supabase — obtienes estos valores en supabase.com al crear el proyecto
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU_ANON_KEY

# ID de la propiedad en Airbnb (número en la URL)
NEXT_PUBLIC_AIRBNB_ROOM_ID=45439655

# URL iCal de Airbnb — la obtienes en Calendario > Sincronizar calendarios > Exportar
AIRBNB_ICAL_URL=https://www.airbnb.com/calendar/ical/45439655.ics?s=TU_TOKEN

# Instagram handle
NEXT_PUBLIC_INSTAGRAM_HANDLE=casatoro.co
